---
// src/components/Footer.astro
const year = new Date().getFullYear();
---
<footer>
  <div class="container grid grid-cols-1 md:grid-cols-2 gap-8 py-12">
    <div>
      <a href="/" class="logo-wrap" aria-label="Nyiroro">
        <img src="/logo.png" alt="Nyiroro" width="56" height="56" />
      </a>
      <p class="tagline">Solusi Digital End-to-End untuk Bisnis Modern</p>
    </div>
    <address>
      <h3>Kontak</h3>
      <ul>
        <li><a href="mailto:halo@nyiroro.id">halo@nyiroro.id</a></li>
        <li><a href="https://wa.me/628123456789" rel="noopener noreferrer" target="_blank">+62 812-3456-7890</a></li>
        <li>Jakarta, Indonesia</li>
      </ul>
    </address>
  </div>
  <div class="copyright">
    <div class="container">
      <small>© {year} Nyiroro. Hak cipta dilindungi.</small>
    </div>
  </div>
</footer>

<style>
  footer {
    background: var(--accent-light);
    border-top: 1px solid var(--border);
  }
  .logo-wrap {
    display: inline-block;
    margin-bottom: 0.5rem;
  }
  .logo-wrap img {
    display: block;
  }
  .tagline { font-size: 0.8rem; color: var(--subtext); line-height: 1.6; }
  h3 {
    font-family: var(--font-heading);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--subtext);
    margin-bottom: 0.75rem;
  }
  ul { display: flex; flex-direction: column; gap: 0.4rem; }
  address { font-style: normal; }
  address li { font-size: 0.875rem; color: var(--text); }
  .copyright {
    border-top: 1px solid var(--border);
    padding-block: 1rem;
  }
  .copyright small { color: var(--subtext); font-size: 0.8rem; }
</style>
