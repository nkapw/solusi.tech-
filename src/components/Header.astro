---
// src/components/Header.astro
---
<header>
  <div class="container flex items-center justify-between py-4">

    <a href="/" class="logo" aria-label="Solusi — Beranda">Solusi</a>

    <!-- Desktop nav -->
    <nav class="nav-desktop" aria-label="Navigasi utama">
      <ul class="flex items-center gap-8">
        <li><a href="#layanan">Layanan</a></li>
        <li><a href="#portofolio">Portofolio</a></li>
        <li><a href="#paket">Paket</a></li>
        <li><a href="#kontak">Kontak</a></li>
        <li><a href="#kontak" class="nav-cta">Konsultasi</a></li>
      </ul>
    </nav>

    <!-- Mobile hamburger — CSS-only toggle via <details> -->
    <details class="nav-mobile">
      <summary class="hamburger" aria-label="Buka navigasi">
        <span></span>
        <span></span>
        <span></span>
      </summary>
      <div class="mobile-menu">
        <nav aria-label="Navigasi utama">
          <ul>
            <li><a href="#layanan">Layanan</a></li>
            <li><a href="#portofolio">Portofolio</a></li>
            <li><a href="#paket">Paket</a></li>
            <li><a href="#kontak">Kontak</a></li>
            <li class="mobile-cta-item"><a href="#kontak" class="nav-cta-mobile">Konsultasi →</a></li>
          </ul>
        </nav>
      </div>
    </details>

  </div>
</header>

<!-- Close mobile menu when any nav link is clicked -->
<script>
  const details = document.querySelector('.nav-mobile');
  details?.querySelectorAll('a').forEach(a => {
    a.addEventListener('click', () => details.removeAttribute('open'));
  });
</script>

<style>
  header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: var(--bg);
    border-bottom: 1px solid var(--border);
  }

  /* Logo */
  .logo {
    font-family: var(--font-mono);
    font-size: 1rem;
    font-weight: bold;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text);
    text-decoration: none;
  }

  /* Desktop nav links */
  .nav-desktop a {
    font-size: 0.8rem;
    color: var(--subtext);
    letter-spacing: 0.03em;
    text-decoration: none;
  }
  .nav-desktop a:hover { color: var(--text); }

  /* CTA pill (desktop) */
  .nav-cta {
    font-size: 0.75rem;
    font-weight: bold;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--text) !important;
    border: 1px solid var(--border);
    padding: 0.35rem 0.9rem;
    transition: background 0.15s, border-color 0.15s;
  }
  .nav-cta:hover {
    background: var(--text);
    color: var(--bg) !important;
    border-color: var(--text);
  }

  /* Mobile nav — hidden on desktop */
  .nav-mobile { display: none; }

  /* Hamburger button (three lines) */
  .hamburger {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    cursor: pointer;
    padding: 4px;
    list-style: none;
  }
  .hamburger::-webkit-details-marker { display: none; }
  .hamburger::marker { display: none; }

  .hamburger span {
    display: block;
    width: 22px;
    height: 2px;
    background: var(--text);
    transition: opacity 0.15s;
  }

  /* Middle line fades out when menu is open */
  details[open] .hamburger span:nth-child(2) { opacity: 0; }

  /* Dropdown menu */
  .mobile-menu {
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    background: var(--bg);
    border-bottom: 1px solid var(--border);
    padding: 0.5rem var(--px) 1.25rem;
  }

  .mobile-menu ul {
    display: flex;
    flex-direction: column;
  }

  .mobile-menu li {
    border-bottom: 1px solid var(--border);
  }

  .mobile-menu a {
    display: block;
    padding: 0.85rem 0;
    font-size: 0.9rem;
    color: var(--text);
    text-decoration: none;
  }

  .mobile-menu a:hover { color: var(--subtext); }

  .mobile-cta-item {
    border-bottom: none !important;
    margin-top: 0.75rem;
  }

  .nav-cta-mobile {
    font-weight: bold;
    font-size: 0.85rem !important;
  }

  /* Show hamburger, hide desktop nav on mobile */
  @media (max-width: 640px) {
    .nav-desktop { display: none; }
    .nav-mobile  { display: block; }
  }
</style>
