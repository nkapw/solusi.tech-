---
// src/components/Header.astro
---
<header>
  <div class="container flex items-center justify-between py-4">

    <a href="/" class="logo" aria-label="Nyiroro — Beranda">
      <img src="/logo.png" alt="Nyiroro" width="40" height="40" />
    </a>

    <div class="right-controls flex items-center gap-4">

      <!-- Desktop nav -->
      <nav class="nav-desktop" aria-label="Navigasi utama">
        <ul class="flex items-center gap-8">
          <li><a href="#layanan">Layanan</a></li>
          <li><a href="#portofolio">Portofolio</a></li>
          <li><a href="#paket">Paket</a></li>
          <li><a href="#kontak">Kontak</a></li>
          <li><a href="#kontak" class="nav-cta">Konsultasi</a></li>
        </ul>
      </nav>

      <!-- Theme toggle — always visible -->
      <button id="theme-toggle" class="theme-btn" aria-label="Aktifkan mode gelap">🌙</button>

      <!-- Mobile hamburger — CSS-only toggle via <details> -->
      <details class="nav-mobile">
        <summary class="hamburger" aria-label="Buka navigasi">
          <span></span>
          <span></span>
          <span></span>
        </summary>
        <div class="mobile-menu">
          <nav aria-label="Navigasi utama">
            <ul>
              <li><a href="#layanan">Layanan</a></li>
              <li><a href="#portofolio">Portofolio</a></li>
              <li><a href="#paket">Paket</a></li>
              <li><a href="#kontak">Kontak</a></li>
              <li class="mobile-cta-item"><a href="#kontak" class="nav-cta-mobile">Konsultasi →</a></li>
            </ul>
          </nav>
        </div>
      </details>

    </div>
  </div>
</header>

<script>
  const btn     = document.getElementById('theme-toggle') as HTMLButtonElement | null;
  const html    = document.documentElement;
  const details = document.querySelector('.nav-mobile') as HTMLDetailsElement | null;

  // Sync button icon with current theme
  function updateIcon() {
    const isDark = html.getAttribute('data-theme') === 'dark';
    if (!btn) return;
    btn.textContent = isDark ? '☀' : '🌙';
    btn.setAttribute('aria-label', isDark ? 'Aktifkan mode terang' : 'Aktifkan mode gelap');
  }

  updateIcon();

  // Toggle theme on click
  btn?.addEventListener('click', () => {
    const next = html.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
    if (next === 'dark') {
      html.setAttribute('data-theme', 'dark');
    } else {
      html.removeAttribute('data-theme');
    }
    localStorage.setItem('theme', next);
    updateIcon();
  });

  // Close mobile menu when a nav link is clicked
  details?.querySelectorAll('a').forEach(a => {
    a.addEventListener('click', () => details.removeAttribute('open'));
  });
</script>

<style>
  header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: var(--bg);
    border-bottom: 1px solid var(--border);
    transition: background-color 0.25s ease, border-color 0.25s ease;
  }

  /* Logo */
  .logo {
    display: flex;
    align-items: center;
    text-decoration: none;
    line-height: 1;
  }
  .logo img {
    display: block;
    height: 40px;
    width: auto;
  }

  /* Desktop nav links */
  .nav-desktop a {
    font-size: 0.8rem;
    color: var(--subtext);
    letter-spacing: 0.03em;
    text-decoration: none;
  }
  .nav-desktop a:hover { color: var(--text); }

  /* CTA pill (desktop) */
  .nav-cta {
    font-size: 0.75rem;
    font-weight: bold;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--text) !important;
    border: 1px solid var(--border);
    padding: 0.35rem 0.9rem;
    transition: background 0.15s, border-color 0.15s, color 0.15s;
  }
  .nav-cta:hover {
    background: var(--text);
    color: var(--bg) !important;
    border-color: var(--text);
  }

  /* Theme toggle button */
  .theme-btn {
    background: none;
    border: none;
    cursor: pointer;
    font-size: 1rem;
    padding: 4px;
    line-height: 1;
    color: var(--subtext);
    transition: color 0.15s;
  }
  .theme-btn:hover { color: var(--text); }
  .theme-btn:focus-visible {
    outline: 2px solid var(--text);
    outline-offset: 3px;
  }

  /* Mobile nav — hidden on desktop */
  .nav-mobile { display: none; }

  /* Hamburger button (three lines) */
  .hamburger {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    cursor: pointer;
    padding: 4px;
    list-style: none;
  }
  .hamburger::-webkit-details-marker { display: none; }
  .hamburger::marker { display: none; }

  .hamburger span {
    display: block;
    width: 22px;
    height: 2px;
    background: var(--text);
    transition: opacity 0.15s;
  }

  details[open] .hamburger span:nth-child(2) { opacity: 0; }

  /* Dropdown menu */
  .mobile-menu {
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    background: var(--bg);
    border-bottom: 1px solid var(--border);
    padding: 0.5rem var(--px) 1.25rem;
    transition: background-color 0.25s ease;
  }

  .mobile-menu ul {
    display: flex;
    flex-direction: column;
  }

  .mobile-menu li {
    border-bottom: 1px solid var(--border);
  }

  .mobile-menu a {
    display: block;
    padding: 0.85rem 0;
    font-size: 0.9rem;
    color: var(--text);
    text-decoration: none;
  }

  .mobile-menu a:hover { color: var(--subtext); }

  .mobile-cta-item {
    border-bottom: none !important;
    margin-top: 0.75rem;
  }

  .nav-cta-mobile {
    font-weight: bold;
    font-size: 0.85rem !important;
  }

  /* Show hamburger, hide desktop nav on mobile */
  @media (max-width: 640px) {
    .nav-desktop { display: none; }
    .nav-mobile  { display: block; }
  }
</style>
