---
// src/components/CTASection.astro
---
<section id="kontak" aria-labelledby="cta-heading" class="cta-section">
  <div class="container">
    <h2 id="cta-heading">Siap Memulai Proyek Anda?</h2>
    <p>
      Konsultasi pertama gratis dan tanpa komitmen. Ceritakan kebutuhan Anda —
      kami siapkan solusi yang tepat dan estimasi biaya yang transparan.
    </p>
    <div class="cta-group flex flex-wrap gap-4 mt-8">
      <a href="mailto:halo@nyiroro.id" class="btn-primary">Kirim Email →</a>
      <a href="https://wa.me/628123456789" rel="noopener noreferrer" target="_blank" class="btn-secondary">
        WhatsApp Kami
      </a>
    </div>
    <p class="note">
      <small>📍 Jakarta, Indonesia &nbsp;·&nbsp; halo@nyiroro.id &nbsp;·&nbsp; +62 812-3456-7890</small>
    </p>
  </div>
</section>

<style>
  .cta-section { background: var(--accent-light); }
  h2 { font-size: clamp(1.375rem, 3vw, 2rem); margin-bottom: 1rem; color: var(--text); }
  p { color: var(--subtext); max-width: 58ch; line-height: 1.8; }
  /* CTA buttons — UI controls, not body links */
  .btn-primary {
    display: inline-block;
    background: var(--text);
    color: var(--bg);
    text-decoration: none;
    padding: 0.6rem 1.25rem;
    font-family: var(--font-body);
    font-weight: bold;
    font-size: 0.875rem;
    letter-spacing: 0.02em;
  }
  .btn-primary:hover { background: var(--accent); }
  .btn-secondary {
    display: inline-block;
    border: 1px solid var(--text);
    color: var(--text);
    text-decoration: none;
    padding: 0.6rem 1.25rem;
    font-family: var(--font-body);
    font-size: 0.875rem;
  }
  .btn-secondary:hover { background: var(--surface); border-color: var(--text); }
  .btn-primary:focus-visible,
  .btn-secondary:focus-visible {
    outline: 2px solid var(--text);
    outline-offset: 3px;
  }
  .note { margin-top: 2rem; }
  .note small { color: var(--subtext); font-size: 0.85rem; }
</style>
